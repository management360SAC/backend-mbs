{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "cotizaciones/proforma-template.pdf", "outDir": "dist/src", "watchAssets": true },
      { "include": "cotizaciones/arial.ttf", "outDir": "dist/src", "watchAssets": true },
      { "include": "cotizaciones/arial-bold.ttf", "outDir": "dist/src", "watchAssets": true }
    ]
  }
}
