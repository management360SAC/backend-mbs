// Prisma schema for CRM-MBS (MySQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/* =========================
   SISTEMA DE AUTENTICACIÓN Y PERMISOS
   ========================= */

model Role {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  
  userRoles        UserRole[]
  rolePermissions  RolePermission[]
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(100)
  module      String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?  @db.Text
  
  rolePermissions RolePermission[]
  
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")
  
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now()) @map("created_at")

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  fullName     String   @map("full_name") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  
  userRoles UserRole[]
  sellerId  Int?       @map("seller_id")
  seller    Seller?    @relation(fields: [sellerId], references: [id])
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model UserRole {
  userId    Int @map("user_id")
  roleId    Int @map("role_id")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

/* =========================
   MODELOS DE NEGOCIO
   ========================= */

model Seller {
  id        Int      @id @default(autoincrement())
  fullName  String   @map("full_name") @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  users     User[]
  leads     Lead[]
  quotes    Quote[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sellers")
}

model LeadSource {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  leads     Lead[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("lead_sources")
}

model FunnelStage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  order     Int      @default(0)
  isClosed  Boolean  @default(false) @map("is_closed")
  leads     Lead[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("funnel_stages")
}

model Lead {
  id             Int         @id @default(autoincrement())
  fullName       String      @map("full_name") @db.VarChar(255)
  email          String?     @db.VarChar(255)
  phone          String?     @db.VarChar(50)
  notes          String?     @db.Text
  expectedValue  Decimal     @default(0) @map("expected_value") @db.Decimal(10, 2)
  sourceId       Int?        @map("source_id")
  source         LeadSource? @relation(fields: [sourceId], references: [id])
  sellerId       Int?        @map("seller_id")
  seller         Seller?     @relation(fields: [sellerId], references: [id])
  currentStageId Int         @map("current_stage_id")
  currentStage   FunnelStage @relation(fields: [currentStageId], references: [id])
  quotes         Quote[]
  payments       Payment[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("leads")
}

model Quote {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  amount      Decimal  @default(0) @db.Decimal(10, 2)
  status      String   @default("DRAFT") @db.VarChar(50)
  leadId      Int      @map("lead_id")
  lead        Lead     @relation(fields: [leadId], references: [id])
  sellerId    Int?     @map("seller_id")
  seller      Seller?  @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("quotes")
}

model Payment {
  id        Int              @id @default(autoincrement())
  type      String           @db.VarChar(50)
  amount    Decimal          @default(0) @db.Decimal(10, 2)
  paidAt    DateTime?        @map("paid_at")
  notes     String?          @db.Text
  leadId    Int              @map("lead_id")
  lead      Lead             @relation(fields: [leadId], references: [id])
  history   PaymentHistory[]
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("payments")
}

model PaymentHistory {
  id        Int      @id @default(autoincrement())
  action    String   @db.VarChar(100)
  detail    String?  @db.Text
  paymentId Int      @map("payment_id")
  payment   Payment  @relation(fields: [paymentId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("payment_history")
}